# DriverLog — Vercel serverless env vars (api/, lib/). site/ itself has no
# secrets and no build step; these only apply to the api/ deployment.
#
# Set these in the Vercel project's dashboard (Settings -> Environment
# Variables), not in a committed .env file.

# ── Database ────────────────────────────────────────────────────────────
# Auto-provisioned by connecting the Neon integration in the Vercel
# dashboard (Storage -> Connect Database) — do not set this by hand, and
# don't rename it; lib/db.js reads exactly this name.
DATABASE_URL=

# After connecting Neon, run sql/schema.sql once against the database from
# Neon's own SQL console (Neon dashboard -> SQL Editor). There is no
# migration runner in this project — that file is the source of truth,
# applied by hand.

# ── Auth tokens ─────────────────────────────────────────────────────────
# Signs/verifies this project's own session tokens (lib/auth.js) — NOT a
# LINE credential, generate this yourself (e.g. `openssl rand -base64 32`).
# Losing/rotating this invalidates every issued token at once.
AUTH_TOKEN_SECRET=

# ── LINE Login — "Log in with LINE" on site/login.html ─────────────────
# Create a channel of type "LINE Login" (not "Messaging API") in the LINE
# Developers Console, then get its Channel ID/secret from that channel's
# "Basic settings" tab.
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# Must exactly match one callback URL registered on the LINE Login channel
# above (LINE Developers Console -> your channel -> LINE Login tab):
#   https://<this-vercel-project>.vercel.app/api/line-login-callback
LINE_LOGIN_CALLBACK_URL=

# Signs the OAuth `state` round-trip (api/line-login-start.js /
# api/line-login-callback.js) — also not a LINE credential, generate this
# yourself too, unrelated to AUTH_TOKEN_SECRET above.
LINE_LOGIN_STATE_SECRET=
